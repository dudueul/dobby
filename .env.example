# Copy to .env and replace every CHANGE_ME. Keep .env out of git.

# --- General ---
TZ=America/New_York
PUID=1000
PGID=1000

# --- PostgreSQL audit DB ---
POSTGRES_DB=dobby
POSTGRES_USER=dobby
POSTGRES_PASSWORD=CHANGE_ME_long_random

# --- MQTT (Mosquitto) ---
MQTT_USER=dobby
MQTT_PASSWORD=CHANGE_ME_long_random

# --- Grafana ---
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_long_random

# --- Nuki ---
# Optional Web API token (outbound poll only). Leave as CHANGE_ME to disable polling
# and rely on local MQTT/Bridge ingestion instead.
NUKI_API_TOKEN=CHANGE_ME_or_leave_to_disable
NUKI_POLL_SECONDS=300

# --- Home Assistant ---
HOME_ASSISTANT_URL=http://homeassistant:8123
HOME_ASSISTANT_TOKEN=CHANGE_ME_long_lived_token

# --- Frigate / cameras ---
FRIGATE_RTSP_USER=CHANGE_ME
FRIGATE_RTSP_PASSWORD=CHANGE_ME

# --- Zigbee / Z-Wave coordinators (set to the stable by-id device paths) ---
ZIGBEE_SERIAL=/dev/serial/by-id/CHANGE_ME
ZWAVE_SERIAL=/dev/serial/by-id/CHANGE_ME
ZWAVE_S2_UNAUTHENTICATED=CHANGE_ME_32_hex
ZWAVE_S2_AUTHENTICATED=CHANGE_ME_32_hex
ZWAVE_S2_ACCESS_CONTROL=CHANGE_ME_32_hex
ZWAVE_S0_LEGACY=CHANGE_ME_32_hex

# --- Storage paths (set in setup-storage.sh) ---
MEDIA_ROOT=/srv/dobby/media
DATA_ROOT=/srv/dobby/data

# --- Backblaze B2 archive (PutObject-only application key) ---
B2_BUCKET=CHANGE_ME
B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com
B2_KEY_ID=CHANGE_ME
B2_APP_KEY=CHANGE_ME
# age recipients file (public keys only on this box). See docs/07.
ARCHIVE_RECIPIENTS=/opt/dobby/secrets/recipients.txt

# Local retention windows (days) before age-out to B2
RETAIN_FULL_VIDEO_DAYS=365
RETAIN_EVENT_VIDEO_DAYS=730
RETAIN_AUDIT_DAYS=1095
# Disk-pressure low-water mark (percent free) that triggers early eviction
DISK_LOW_WATER_PCT=15
